// ─── SHARED UI ────────────────────────────────────────────────────────────────
function Card({ children, style={}, ...r }) {
  return <div style={{ background:C.white, border:`1px solid ${C.lightGrey}`, borderRadius:4, ...style }} {...r}>{children}</div>;
}

function SectionHead({ label, sub, action }) {
  return (
    <div style={{ display:"flex", justifyContent:"space-between", alignItems:"flex-end", marginBottom:14 }}>
      <div style={{ display:"flex", alignItems:"center", gap:8 }}>
        <div style={{ width:3, height:16, background:C.eucalyptus, borderRadius:2 }} />
        <div>
          <div style={{ color:C.charcoal, fontSize:11, fontFamily:"'DM Mono',monospace", fontWeight:600, letterSpacing:"0.12em" }}>{label}</div>
          {sub && <div style={{ color:C.wheatDark, fontSize:9, fontFamily:"'DM Mono',monospace", marginTop:1 }}>{sub}</div>}
        </div>
      </div>
      {action}
    </div>
  );
}

function Btn({ children, onClick, disabled, variant="green", style={} }) {
  const bg = disabled ? C.lightGrey : variant==="green" ? C.eucalyptus : variant==="navy" ? C.navy : C.white;
  const color = variant==="outline" ? C.charcoal : C.white;
  const border = variant==="outline" ? `1px solid ${C.lightGrey}` : "none";
  return (
    <button onClick={onClick} disabled={disabled} style={{
      background:bg, color, border, borderRadius:3, padding:"8px 16px",
      cursor:disabled?"not-allowed":"pointer", fontSize:11,
      fontFamily:"'DM Mono',monospace", fontWeight:600,
      transition:"all 0.15s", letterSpacing:"0.04em", ...style,
    }}
    onMouseEnter={e=>{ if(!disabled&&variant==="green") e.currentTarget.style.background=C.eucalyptusLight; }}
    onMouseLeave={e=>{ if(!disabled&&variant==="green") e.currentTarget.style.background=C.eucalyptus; }}
    >{children}</button>
  );
}

function Spinner() {
  return <span style={{ display:"inline-block", width:12, height:12, border:`2px solid ${C.lightGrey}`, borderTopColor:C.eucalyptus, borderRadius:"50%", animation:"spin 0.8s linear infinite", marginRight:6 }} />;
}

// ─── ARTICLE CARD ─────────────────────────────────────────────────────────────
function ArticleCard({ article, onDeepDive }) {
  const [expanded, setExpanded] = useState(false);
  const catStyle = CAT_COLOR[article.category] || { bg:C.eggshell, color:C.charcoal };
  const sentColor = article.sentiment==="bullish" ? C.eucalyptus : article.sentiment==="bearish" ? C.negative : C.warning;
  const borderColor = article.sentiment==="bullish" ? C.eucalyptus : article.sentiment==="bearish" ? C.negative : C.warning;

  return (
    <Card style={{ borderLeft:`4px solid ${borderColor}`, padding:"14px 16px", marginBottom:8, transition:"box-shadow 0.15s", cursor:"pointer" }}
      onMouseEnter={e=>e.currentTarget.style.boxShadow="0 2px 12px rgba(0,0,0,0.08)"}
      onMouseLeave={e=>e.currentTarget.style.boxShadow="none"}
    >
      {/* Meta row */}
      <div style={{ display:"flex", justifyContent:"space-between", alignItems:"center", marginBottom:7, flexWrap:"wrap", gap:6 }}>
        <div style={{ display:"flex", gap:5, alignItems:"center", flexWrap:"wrap" }}>
          <span style={{ fontSize:9, padding:"2px 7px", borderRadius:2, fontFamily:"'DM Mono',monospace", fontWeight:600, color:catStyle.color, background:catStyle.bg, border:`1px solid ${catStyle.color}22` }}>{article.category}</span>
          <span style={{ fontSize:9, padding:"2px 6px", borderRadius:2, fontFamily:"'DM Mono',monospace", fontWeight:600, color:C.charcoal, background:C.eggshell, border:`1px solid ${C.lightGrey}` }}>{article.source}</span>
          <span style={{ fontSize:9, padding:"2px 7px", borderRadius:2, fontFamily:"'DM Mono',monospace", fontWeight:700, color:sentColor, background:`${sentColor}15`, border:`1px solid ${sentColor}33` }}>{article.sentiment.toUpperCase()}</span>
          {article.relevance==="high" && <span style={{ fontSize:9, padding:"2px 7px", borderRadius:2, fontFamily:"'DM Mono',monospace", fontWeight:700, color:C.eucalyptus, background:C.eucalyptusPale, border:`1px solid ${C.eucalyptus}33` }}>⚡ HIGH RELEVANCE</span>}
        </div>
        <span style={{ color:C.lightGrey, fontSize:10, fontFamily:"'DM Mono',monospace", flexShrink:0 }}>{article.time}</span>
      </div>

      {/* Headline */}
      <a href={article.url} target="_blank" rel="noopener noreferrer" style={{ color:C.charcoal, fontSize:13, fontWeight:600, lineHeight:1.45, textDecoration:"none", display:"block", marginBottom:10 }}
        onMouseEnter={e=>e.target.style.color=C.navy}
        onMouseLeave={e=>e.target.style.color=C.charcoal}
      >{article.headline}</a>

      {/* Summary */}
      <div style={{ padding:"10px 12px", background:C.offwhite, borderRadius:3, borderLeft:`2px solid ${C.wheat}`, marginBottom:10 }}>
        <div style={{ color:C.wheat, fontSize:9, fontFamily:"'DM Mono',monospace", fontWeight:700, letterSpacing:"0.1em", marginBottom:5 }}>◆ WHY THIS MATTERS</div>
        <div style={{ color:C.charcoal, fontSize:12, lineHeight:1.65 }}>{article.summary}</div>
      </div>

      {/* Deep dive */}
      {expanded && article.deepDive && (
        <div style={{ padding:"10px 12px", background:C.navyPale, borderRadius:3, borderLeft:`2px solid ${C.navy}`, marginBottom:10, animation:"fadeIn 0.3s ease" }}>
          <div style={{ color:C.navy, fontSize:9, fontFamily:"'DM Mono',monospace", fontWeight:700, letterSpacing:"0.1em", marginBottom:5 }}>◆ DEEP DIVE ANALYSIS</div>
          <div style={{ color:C.charcoal, fontSize:12, lineHeight:1.65 }}>{article.deepDive}</div>
        </div>
      )}

      {/* Footer */}
      <div style={{ display:"flex", justifyContent:"space-between", alignItems:"center" }}>
        <a href={article.url} target="_blank" rel="noopener noreferrer" style={{ color:C.wheat, fontSize:10, fontFamily:"'DM Mono',monospace", textDecoration:"none" }}
          onMouseEnter={e=>e.target.style.textDecoration="underline"}
          onMouseLeave={e=>e.target.style.textDecoration="none"}
        >{article.source} →</a>
        <Btn variant="outline" style={{ fontSize:10, padding:"4px 10px" }}
          onClick={() => {
            if (!article.deepDive) { onDeepDive(article.id); setExpanded(true); }
            else setExpanded(!expanded);
          }}
        >
          {article.deepDive ? (expanded ? "▲ Hide" : "▼ Deep dive") : "◆ Deep dive"}
        </Btn>
      </div>
    </Card>
  );
}

// ─── FEED TAB ─────────────────────────────────────────────────────────────────
function FeedTab({ articles, sources, onDeepDive, onRefresh, loading }) {
  const [category, setCategory] = useState("All");
  const filtered = category==="All" ? articles : articles.filter(a=>a.category===category);
  const high = filtered.filter(a=>a.relevance==="high").length;
  const bullish = filtered.filter(a=>a.sentiment==="bullish").length;
  const bearish = filtered.filter(a=>a.sentiment==="bearish").length;

  return (
    <div>
      {/* Stats */}
      <div style={{ display:"grid", gridTemplateColumns:"repeat(4,1fr)", gap:10, marginBottom:20 }}>
        {[
          { l:"ARTICLES",        v:filtered.length,        c:C.navy       },
          { l:"HIGH RELEVANCE",  v:high,                   c:C.eucalyptus },
          { l:"BULLISH SIGNALS", v:bullish,                c:C.eucalyptus },
          { l:"BEARISH SIGNALS", v:bearish,                c:C.negative   },
        ].map((s,i)=>(
          <Card key={i} style={{ padding:"12px 14px" }}>
            <div style={{ color:C.wheatDark, fontSize:9, fontFamily:"'DM Mono',monospace", letterSpacing:"0.1em", marginBottom:4 }}>{s.l}</div>
            <div style={{ color:s.c, fontSize:22, fontFamily:"'DM Mono',monospace", fontWeight:700 }}>{s.v}</div>
          </Card>
        ))}
      </div>

      <SectionHead
        label="FILTERED & SUMMARISED BY CLAUDE"
        sub={`${sources.filter(s=>s.active).length} active sources · AI assesses relevance and explains why each article matters`}
        action={
          <Btn onClick={onRefresh} disabled={loading} style={{ padding:"7px 14px" }}>
            {loading ? <><Spinner/>FETCHING...</> : "↺ REFRESH FEED"}
          </Btn>
        }
      />

      {/* Category filter pills */}
      <div style={{ display:"flex", gap:6, flexWrap:"wrap", marginBottom:16 }}>
        {CATEGORIES.map(c=>{
          const count = c==="All" ? articles.length : articles.filter(a=>a.category===c).length;
          const isActive = category===c;
          return (
            <button key={c} onClick={()=>setCategory(c)} style={{
              padding:"4px 12px", borderRadius:20, fontSize:11,
              fontFamily:"'DM Mono',monospace", fontWeight:500,
              cursor:"pointer", border:`1px solid ${isActive?C.eucalyptus:C.lightGrey}`,
              background: isActive?C.eucalyptus:C.white,
              color: isActive?C.white:C.wheatDark,
              transition:"all 0.15s",
            }}>
              {c}{c!=="All"&&count>0?` ${count}`:""}
            </button>
          );
        })}
      </div>

      {/* Articles */}
      {filtered.length===0 ? (
        <div style={{ textAlign:"center", padding:"40px 20px", color:C.wheatDark }}>
          <div style={{ fontSize:32, marginBottom:10 }}>📭</div>
          <div>No articles in this category</div>
        </div>
      ) : (
        filtered.map(a=><ArticleCard key={a.id} article={a} onDeepDive={onDeepDive}/>)
      )}

      <div style={{ padding:"8px 12px", background:C.offwhite, border:`1px dashed ${C.lightGrey}`, borderRadius:3, marginTop:8 }}>
        <span style={{ color:C.wheatDark, fontSize:10, fontFamily:"'DM Mono',monospace" }}>
          ⚡ HOOK: In production, Muster fetches all active RSS feeds via a CORS proxy on page load and every 30 minutes. Claude reads every headline + description, scores relevance 0–10, discards scores below 6, and writes the "Why This Matters" summary for each keeper. Add your NewsAPI key to pull from 80,000+ sources.
        </span>
      </div>
    </div>
  );
}

// ─── DIGEST TAB ───────────────────────────────────────────────────────────────
function DigestTab({ articles, sources }) {
  const [digest, setDigest] = useState("");
  const [loading, setLoading] = useState(false);
  const [generated, setGenerated] = useState(false);

  async function generate() {
    setLoading(true); setDigest(""); setGenerated(false);
    const articleContext = articles.slice(0,12).map(a =>
      `- ${a.headline} (${a.source}, ${a.category}, ${a.sentiment}): ${a.summary}`
    ).join("\n");
    try {
      const res = await fetch("https://api.anthropic.com/v1/messages", {
        method:"POST", headers:{"Content-Type":"application/json"},
        body:JSON.stringify({
          model:"claude-sonnet-4-20250514", max_tokens:1000,
          system:`You are Muster's intelligence analyst writing a daily briefing for a new commodity trader in Australia. Synthesise the provided articles into a structured daily digest. Use this exact format:

☀️ TOP 3 THINGS TO KNOW TODAY
• [Most important development and why it matters]
• [Second most important]
• [Third most important]

📊 BY CATEGORY
Grains & oilseeds: [1-2 sentences]
Livestock & meat: [1-2 sentences]
Wool & fibre: [1-2 sentences]
Ag finance & equities: [1-2 sentences]
Macro & currencies: [1-2 sentences]
Geopolitics: [1-2 sentences]
Weather: [1-2 sentences]
Australian Ag: [1-2 sentences]

👁️ WHAT TO WATCH TODAY
• [Specific report, price level, or event to monitor]
• [Second thing to watch]
• [Third thing to watch]

Be direct and specific. Explain the trading implications clearly.`,
          messages:[{ role:"user", content:`Generate today's daily digest (${new Date().toLocaleDateString("en-AU",{weekday:"long",day:"numeric",month:"long",year:"numeric"})}) based on these ${articles.length} articles:\n\n${articleContext}` }]
        })
      });
      const data = await res.json();
      setDigest(data.content?.map(b=>b.text||"").join("")||"Could not generate digest.");
      setGenerated(true);
    } catch { setDigest("Connection error."); }
    setLoading(false);
  }

  return (
    <div>
      <SectionHead
        label="DAILY INTELLIGENCE DIGEST"
        sub="Claude synthesises everything from the last 24hrs into one structured briefing"
        action={
          <Btn onClick={generate} disabled={loading} style={{ padding:"7px 14px" }}>
            {loading ? <><Spinner/>GENERATING...</> : generated ? "↺ REFRESH" : "☀️ GENERATE DIGEST"}
          </Btn>
        }
      />

      {!digest && !loading && (
        <Card style={{ padding:40, textAlign:"center" }}>
          <div style={{ fontSize:40, marginBottom:14 }}>📋</div>
          <div style={{ color:C.charcoal, fontSize:15, fontWeight:700, marginBottom:8 }}>Generate your daily intelligence digest</div>
          <div style={{ color:C.wheatDark, fontSize:13, lineHeight:1.6, maxWidth:460, margin:"0 auto 20px" }}>
            Claude reads all {articles.length} articles across your {sources.filter(s=>s.active).length} active sources, identifies the most important themes, and writes a structured briefing explaining what it all means for your Ag and commodity positions.
          </div>
          <Btn onClick={generate}>☀️ GENERATE NOW</Btn>
        </Card>
      )}

      {loading && (
        <Card style={{ padding:24 }}>
          <div style={{ color:C.wheatDark, fontSize:13, fontFamily:"'DM Mono',monospace" }}>
            <Spinner/>
            Claude is reading {articles.length} articles across {sources.filter(s=>s.active).length} sources and synthesising your daily briefing...
          </div>
        </Card>
      )}

      {digest && !loading && (
        <Card style={{ padding:22, borderLeft:`4px solid ${C.wheat}` }}>
          <div style={{ color:C.charcoal, fontSize:15, fontWeight:700, marginBottom:4 }}>☀️ Muster Daily Intelligence Digest</div>
          <div style={{ color:C.wheatDark, fontSize:11, fontFamily:"'DM Mono',monospace", marginBottom:16 }}>
            {new Date().toLocaleDateString("en-AU",{weekday:"long",day:"numeric",month:"long",year:"numeric"})} · {sources.filter(s=>s.active).length} sources · {articles.length} articles analysed
          </div>
          <div style={{ color:C.charcoal, fontSize:13, lineHeight:1.8, whiteSpace:"pre-wrap" }}>{digest}</div>
          <div style={{ marginTop:16, display:"flex", gap:8 }}>
            <Btn variant="outline" onClick={generate} style={{ fontSize:10, padding:"6px 12px" }}>↺ Regenerate</Btn>
          </div>
        </Card>
      )}
    </div>
  );
}

