// ─── UPLOAD TAB ───────────────────────────────────────────────────────────────
function UploadTab({ docs, onAddDoc }) {
  const [urlInput, setUrlInput] = useState("");
  const [urlLoading, setUrlLoading] = useState(false);
  const [pasteText, setPasteText] = useState("");
  const [pasteSource, setPasteSource] = useState("");
  const [pasteLoading, setPasteLoading] = useState(false);
  const [dragOver, setDragOver] = useState(false);
  const fileRef = useRef();

  const inputStyle = { padding:"9px 12px", border:`1px solid ${C.lightGrey}`, borderRadius:3, fontSize:12, fontFamily:"'Inter',sans-serif", color:C.charcoal, outline:"none" };

  async function callClaude(prompt) {
    try {
      const res = await fetch("https://api.anthropic.com/v1/messages", {
        method:"POST", headers:{"Content-Type":"application/json"},
        body:JSON.stringify({
          model:"claude-sonnet-4-20250514", max_tokens:600,
          system:"You are an expert agricultural commodity market analyst. The user is a new commodity trader based in Australia. Analyse the provided content and give direct, specific commentary on its trading implications for Ag and commodity markets. Be educational and explain the WHY behind your analysis.",
          messages:[{ role:"user", content:prompt }]
        })
      });
      const data = await res.json();
      return data.content?.map(b=>b.text||"").join("")||"No response.";
    } catch { return "Connection error."; }
  }

  async function analyseUrl() {
    if (!urlInput.trim()) return;
    setUrlLoading(true);
    const summary = await callClaude(`Analyse this article for an Australian Ag commodity trader. URL: ${urlInput}\n\nPlease provide:\n1. What category this falls into (Grains, Livestock, Wool, Ag Finance, Macro, Geopolitics, Weather, AU Domestic Ag)\n2. Whether this is bullish, bearish, or neutral for commodity markets\n3. Relevance score 1-10 for an Ag commodity trader\n4. A 3-4 sentence summary of why this matters and the specific trading implications`);
    onAddDoc({ id:Date.now(), title:`Article: ${urlInput.substring(0,60)}...`, source:"URL Analysis", type:"Web Article", time:"Just now", summary, url:urlInput });
    setUrlInput(""); setUrlLoading(false);
  }

  async function analyseText() {
    if (!pasteText.trim()) return;
    setPasteLoading(true);
    const source = pasteSource || "Pasted content";
    const summary = await callClaude(`Analyse this content for an Australian Ag commodity trader. Source: ${source}\n\nContent:\n${pasteText.substring(0,3000)}\n\nProvide:\n1. The key findings or data points\n2. Which commodity markets are affected and how\n3. Whether this is bullish, bearish, or neutral overall\n4. Specific trading implications — what should a trader do with this information?`);
    onAddDoc({ id:Date.now(), title:`${source} — ${pasteText.substring(0,50)}...`, source, type:"Pasted Text", time:"Just now", summary });
    setPasteText(""); setPasteSource(""); setPasteLoading(false);
  }

  async function processFile(file) {
    const text = await file.text().catch(()=>"Could not read file");
    const summary = await callClaude(`Analyse this document for an Australian Ag commodity trader.\nFile: ${file.name}\n\nContent (first 3000 chars):\n${text.substring(0,3000)}\n\nProvide:\n1. What type of document this is (broker note, research report, market update etc.)\n2. Key findings, data points, and recommendations\n3. Trading implications for Ag/commodity markets\n4. Relevance score 1-10 and which commodities are most affected`);
    onAddDoc({ id:Date.now(), title:file.name, source:"PDF Upload", type:"PDF / Document", time:"Just now", summary });
  }

  function handleDrop(e) {
    e.preventDefault(); setDragOver(false);
    const file = e.dataTransfer.files[0];
    if (file) processFile(file);
  }

  return (
    <div>
      <SectionHead label="PDF & URL UPLOAD" sub="Drop broker notes, paste article URLs, or paste any text — Claude reads and summarises"/>

      {/* URL */}
      <Card style={{ padding:16, marginBottom:14 }}>
        <div style={{ color:C.charcoal, fontSize:11, fontFamily:"'DM Mono',monospace", fontWeight:600, marginBottom:10 }}>PASTE ARTICLE URL</div>
        <div style={{ display:"flex", gap:8, marginBottom:8 }}>
          <input style={{ ...inputStyle, flex:1 }} placeholder="Paste any article URL — AFR, Reuters, broker research, Bloomberg..." value={urlInput} onChange={e=>setUrlInput(e.target.value)} onKeyDown={e=>e.key==="Enter"&&analyseUrl()}
            onFocus={e=>e.target.style.borderColor=C.eucalyptus} onBlur={e=>e.target.style.borderColor=C.lightGrey}
          />
          <Btn onClick={analyseUrl} disabled={urlLoading}>
            {urlLoading?<><Spinner/>ANALYSING...</>:"◆ ANALYSE"}
          </Btn>
        </div>
        <div style={{ color:C.wheatDark, fontSize:11 }}>Works with any public article URL. For paywalled content, paste the article text below instead.</div>
      </Card>

      {/* Text paste */}
      <Card style={{ padding:16, marginBottom:14 }}>
        <div style={{ color:C.charcoal, fontSize:11, fontFamily:"'DM Mono',monospace", fontWeight:600, marginBottom:10 }}>PASTE ARTICLE TEXT OR TRANSCRIPT</div>
        <textarea value={pasteText} onChange={e=>setPasteText(e.target.value)} rows={5} placeholder="Paste article text, broker research note, email newsletter, podcast transcript, or any content you want Claude to analyse..." style={{ ...inputStyle, width:"100%", resize:"vertical", fontFamily:"'Inter',sans-serif", marginBottom:8 }}
          onFocus={e=>e.target.style.borderColor=C.eucalyptus} onBlur={e=>e.target.style.borderColor=C.lightGrey}
        />
        <div style={{ display:"flex", gap:8 }}>
          <input style={{ ...inputStyle, flex:1 }} placeholder="Source name (e.g. AFR, Broker note, Substack)" value={pasteSource} onChange={e=>setPasteSource(e.target.value)}
            onFocus={e=>e.target.style.borderColor=C.eucalyptus} onBlur={e=>e.target.style.borderColor=C.lightGrey}
          />
          <Btn onClick={analyseText} disabled={pasteLoading}>
            {pasteLoading?<><Spinner/>ANALYSING...</>:"◆ ANALYSE TEXT"}
          </Btn>
        </div>
      </Card>

      {/* PDF drop zone */}
      <div
        onDragOver={e=>{e.preventDefault();setDragOver(true);}}
        onDragLeave={()=>setDragOver(false)}
        onDrop={handleDrop}
        onClick={()=>fileRef.current?.click()}
        style={{
          border:`2px dashed ${dragOver?C.eucalyptus:C.lightGrey}`,
          borderRadius:4, padding:30, textAlign:"center", cursor:"pointer",
          background:dragOver?C.eucalyptusPale:C.offwhite,
          transition:"all 0.2s", marginBottom:16,
        }}
      >
        <input ref={fileRef} type="file" accept=".pdf,.txt,.csv" style={{ display:"none" }} onChange={e=>{if(e.target.files[0])processFile(e.target.files[0]);}}/>
        <div style={{ fontSize:32, marginBottom:8 }}>📄</div>
        <div style={{ color:C.charcoal, fontSize:13, fontWeight:500, marginBottom:4 }}>Drop PDF broker notes or research here</div>
        <div style={{ color:C.wheatDark, fontSize:11, fontFamily:"'DM Mono',monospace" }}>PDF · TXT · CSV · Click to browse or drag and drop</div>
      </div>

      {/* Analysed docs */}
      {docs.length > 0 && (
        <div>
          <SectionHead label="ANALYSED DOCUMENTS" sub={`${docs.length} document${docs.length>1?"s":""} analysed`}/>
          {docs.map(doc=>(
            <Card key={doc.id} style={{ padding:"14px 16px", marginBottom:8, borderLeft:`4px solid ${C.eucalyptus}`, animation:"fadeIn 0.3s ease" }}>
              <div style={{ display:"flex", gap:6, alignItems:"center", marginBottom:6, flexWrap:"wrap" }}>
                <span style={{ fontSize:9, padding:"2px 7px", borderRadius:2, fontFamily:"'DM Mono',monospace", fontWeight:600, color:C.navy, background:C.navyPale, border:`1px solid ${C.navy}22` }}>📄 {doc.type}</span>
                <span style={{ fontSize:9, padding:"2px 6px", borderRadius:2, fontFamily:"'DM Mono',monospace", color:C.charcoal, background:C.eggshell, border:`1px solid ${C.lightGrey}` }}>{doc.source}</span>
                <span style={{ fontSize:9, padding:"2px 7px", borderRadius:2, fontFamily:"'DM Mono',monospace", fontWeight:700, color:C.eucalyptus, background:C.eucalyptusPale }}>⚡ UPLOADED</span>
                <span style={{ color:C.lightGrey, fontSize:10, fontFamily:"'DM Mono',monospace", marginLeft:"auto" }}>{doc.time}</span>
              </div>
              <div style={{ color:C.charcoal, fontSize:13, fontWeight:600, marginBottom:8, lineHeight:1.3 }}>{doc.title}</div>
              <div style={{ padding:"10px 12px", background:C.offwhite, borderRadius:3, borderLeft:`2px solid ${C.wheat}` }}>
                <div style={{ color:C.wheat, fontSize:9, fontFamily:"'DM Mono',monospace", fontWeight:700, letterSpacing:"0.1em", marginBottom:5 }}>◆ CLAUDE'S ANALYSIS</div>
                <div style={{ color:C.charcoal, fontSize:12, lineHeight:1.65 }}>{doc.summary}</div>
              </div>
            </Card>
          ))}
        </div>
      )}
    </div>
  );
}

// ─── MAIN COMPONENT ───────────────────────────────────────────────────────────
export default function IntelligenceFeed() {
  const [activeTab, setActiveTab] = useState("feed");
  const [sources, setSources] = useState(DEFAULT_SOURCES);
  const [articles, setArticles] = useState(SIMULATED_ARTICLES);
  const [uploadedDocs, setUploadedDocs] = useState([]);
  const [feedLoading, setFeedLoading] = useState(false);

  async function handleRefresh() {
    setFeedLoading(true);
    // PRODUCTION: fetch all active RSS feeds via CORS proxy, send to Claude for filtering + summarising
    // For now simulate delay
    await new Promise(r=>setTimeout(r,1500));
    setFeedLoading(false);
  }

  async function handleDeepDive(id) {
    const article = articles.find(a=>a.id===id);
    if (!article || article.deepDive) return;
    try {
      const res = await fetch("https://api.anthropic.com/v1/messages", {
        method:"POST", headers:{"Content-Type":"application/json"},
        body:JSON.stringify({
          model:"claude-sonnet-4-20250514", max_tokens:700,
          system:"You are an expert agricultural commodity market analyst. Give a detailed deep dive analysis for an Australian Ag commodity trader. Be specific, educational, and actionable.",
          messages:[{ role:"user", content:`Deep dive analysis for this news:\n\nHeadline: ${article.headline}\nSource: ${article.source}\nCategory: ${article.category}\nSentiment: ${article.sentiment}\nInitial summary: ${article.summary}\n\nProvide: (1) Full context and background, (2) Which specific markets/prices are affected and how, (3) What to watch as follow-up signals, (4) How this connects to other current market themes. 3-4 paragraphs.` }]
        })
      });
      const data = await res.json();
      const deepDive = data.content?.map(b=>b.text||"").join("")||"";
      setArticles(prev=>prev.map(a=>a.id===id?{...a,deepDive}:a));
    } catch(e) { console.error(e); }
  }

  const TABS = [
    { id:"feed",    label:"INTELLIGENCE FEED", count:articles.length },
    { id:"digest",  label:"DAILY DIGEST",      count:0              },
    { id:"sources", label:"SOURCES",           count:sources.filter(s=>s.active).length },
    { id:"upload",  label:"PDF & URL UPLOAD",  count:uploadedDocs.length },
  ];

  return (
    <div>
      <style>{`
        @keyframes spin { to{transform:rotate(360deg)} }
        @keyframes fadeIn { from{opacity:0;transform:translateY(4px)} to{opacity:1;transform:translateY(0)} }
        @keyframes blink { 0%,100%{opacity:1} 50%{opacity:0} }
      `}</style>

      {/* Header banner */}
      <div style={{ background:`linear-gradient(135deg, ${C.navy} 0%, ${C.eucalyptus} 100%)`, borderRadius:6, padding:"16px 22px", marginBottom:18, display:"flex", justifyContent:"space-between", alignItems:"center" }}>
        <div style={{ display:"flex", alignItems:"center", gap:12 }}>
          <span style={{ fontSize:26 }}>🧠</span>
          <div>
            <div style={{ color:C.wheat, fontSize:17, fontWeight:700, fontFamily:"'DM Mono',monospace", letterSpacing:"0.12em" }}>INTELLIGENCE FEED</div>
            <div style={{ color:"rgba(255,255,255,0.6)", fontSize:11, fontFamily:"'DM Mono',monospace" }}>
              {sources.filter(s=>s.active).length} active sources · {articles.length} articles · Claude-filtered & summarised
            </div>
          </div>
        </div>
        <div style={{ display:"flex", gap:20 }}>
          {[
            ["ARTICLES",    articles.length,                               C.wheat ],
            ["HIGH RELEVANCE", articles.filter(a=>a.relevance==="high").length, "#7de8a0"],
            ["BULLISH",     articles.filter(a=>a.sentiment==="bullish").length, "#7de8a0"],
            ["BEARISH",     articles.filter(a=>a.sentiment==="bearish").length, "#f87171"],
          ].map(([l,v,c])=>(
            <div key={l} style={{ textAlign:"right" }}>
              <div style={{ color:"rgba(255,255,255,0.5)", fontSize:9, fontFamily:"'DM Mono',monospace", marginBottom:2 }}>{l}</div>
              <div style={{ color:c, fontSize:18, fontFamily:"'DM Mono',monospace", fontWeight:700 }}>{v}</div>
            </div>
          ))}
        </div>
      </div>

      {/* Sub tab nav */}
      <div style={{ background:C.white, border:`1px solid ${C.lightGrey}`, borderRadius:4, padding:"4px 6px", marginBottom:18, display:"flex", gap:2, overflowX:"auto" }}>
        {TABS.map(t=>(
          <button key={t.id} onClick={()=>setActiveTab(t.id)} style={{
            background: activeTab===t.id ? C.eggshell : "none",
            border: `1px solid ${activeTab===t.id?C.lightGrey:"transparent"}`,
            borderRadius:3, padding:"7px 14px", cursor:"pointer",
            fontFamily:"'DM Mono',monospace", fontSize:10, fontWeight: activeTab===t.id?600:400,
            letterSpacing:"0.08em", color: activeTab===t.id?C.eucalyptus:C.wheatDark,
            transition:"all 0.15s", whiteSpace:"nowrap",
          }}
          onMouseEnter={e=>{if(activeTab!==t.id)e.target.style.color=C.charcoal;}}
          onMouseLeave={e=>{if(activeTab!==t.id)e.target.style.color=C.wheatDark;}}
          >
            {t.label}
            {t.count>0 && <span style={{ display:"inline-flex", alignItems:"center", justifyContent:"center", background:C.eucalyptus, color:"white", borderRadius:10, fontSize:8, padding:"1px 5px", marginLeft:5, fontWeight:700 }}>{t.count}</span>}
          </button>
        ))}
      </div>

      {/* Tab content */}
      <div style={{ animation:"fadeIn 0.2s ease" }}>
        {activeTab==="feed"    && <FeedTab    articles={articles} sources={sources} onDeepDive={handleDeepDive} onRefresh={handleRefresh} loading={feedLoading}/>}
        {activeTab==="digest"  && <DigestTab  articles={articles} sources={sources}/>}
        {activeTab==="sources" && <SourcesTab sources={sources} onToggle={id=>setSources(p=>p.map(s=>s.id===id?{...s,active:!s.active}:s))} onAdd={s=>setSources(p=>[...p,s])} onRemove={id=>setSources(p=>p.filter(s=>s.id!==id))}/>}
        {activeTab==="upload"  && <UploadTab  docs={uploadedDocs} onAddDoc={doc=>setUploadedDocs(p=>[doc,...p])}/>}
      </div>
    </div>
  );
}
